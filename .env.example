# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=fepublica
POSTGRES_PASSWORD=change_me_in_real_deployments
POSTGRES_DB=fepublica
POSTGRES_SSLMODE=disable

# Portal da Transparencia API
# Cadastre-se em https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
# e coloque o token recebido por email aqui.
TRANSPARENCIA_API_KEY=

# OpenTimestamps calendar servers (comma separated, official public calendars by default)
OTS_CALENDARS=https://alice.btc.calendar.opentimestamps.org,https://bob.btc.calendar.opentimestamps.org,https://finney.calendar.eternitywall.com

# Collector cadence
COLLECTOR_CEIS_SCHEDULE=0 4 * * *
COLLECTOR_CNEP_SCHEDULE=15 4 * * *

# Batcher cadence (how often to build Merkle tree and anchor)
ANCHOR_BATCH_INTERVAL=6h

# HTTP API
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_URL=https://fepublica.gmowses.cloud

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Optional: external storage for large payloads (S3 compatible)
# Leave empty to store everything in Postgres
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
